erminacy<\\/b>: >40-60 percent indeterminacy (first prospect of release at 40-59.99 percent of judicial maximum).\\\" tabindex=\\\"0\\\" role=\\\"button\\\">Prison Sentencing<br>System&#9432;<\\/span>\"},\"evals\":[],\"jsHooks\":[]}</script>\n</div>\n</div>\n```\n:::\n:::\n\n:::\n\n<br>\n\n\n\n::: panel-tabset \n\n## Overview\n\n<center>\n\n::: {.cell}\n::: {.cell-output-display}\n```{=html}\n<div id=\"body-section\">\n<div id=\"htmlwidget-69a65dd00ea33e3eafa5\" style=\"width:100%;height:541px;\" class=\"highchart html-widget \"></div>\n<script type=\"application/json\" data-for=\"htmlwidget-69a65dd00ea33e3eafa5\">{\"x\":{\"hc_opts\":{\"chart\":{\"reflow\":true,\"width\":600,\"height\":500},\"title\":{\"text\":\"Trends in Prison Population, Releases to Parole, and Parole Eligibility\"},\"yAxis\":{\"title\":{\"text\":null},\"labels\":{\"format\":\"{value:,.0f}\"}},\"credits\":{\"enabled\":false},\"exporting\":{\"enabled\":true},\"boost\":{\"enabled\":false},\"plotOptions\":{\"series\":{\"label\":{\"enabled\":false},\"turboThreshold\":0},\"treemap\":{\"layoutAlgorithm\":\"squarified\"},\"column\":{\"dataLabels\":{\"enabled\":true}}},\"xAxis\":{\"categories\":[2010,2012,2013,2014,2015,2016,2018,2019,2020],\"labels\":{\"format\":\"{value}\"}},\"series\":[{\"name\":\"Prison Population\",\"data\":[7207,6282,7687,7231,6904,8138,8664,9434,8334]},{\"name\":\"Released from Prison to Parole\",\"data\":[1522,1250,1408,1784,2030,1701,1907,null,null]},{\"name\":\"Parole Eligible but not Released from Prison\",\"data\":[1860,null,2917,2417,2132,2732,2815,3416,3129]}],\"colors\":[\"#00aba0\",\"#ffaf00\",\"#ff6400\"],\"tooltip\":{\"shared\":true,\"crosshairs\":true}},\"theme\":{\"colors\":[\"#ff6400\",\"#ffaf00\",\"#c376fb\",\"#003474\",\"#00aba0\",\"#0061e4\"],\"chart\":{\"style\":{\"fontFamily\":\"Graphik\",\"color\":\"#3E4B4B\"}},\"title\":{\"align\":\"center\",\"style\":{\"fontFamily\":\"Graphik\",\"fontWeight\":\"bold\",\"color\":\"#3E4B4B\",\"fontSize\":\"18px\"}},\"subtitle\"